# Приклад налаштувань LMS для Tutor plugin або patches/openedx-lms-production-settings
#
# Додайте у Tutor plugin (tutor-contrib-zrozumilo) або вручну в env:

ZROZUMILOAI_WIDGET_JS_URL = "https://chat.example.com/widget.js"
ZROZUMILOAI_WIDGET_TOKEN = "wt_ВАШ_TOKEN"
ZROZUMILOAI_WIDGET_TITLE = "Підтримка"
ZROZUMILOAI_WIDGET_COLOR = "#0D9E96"

# CSP (приклад — адаптуйте під ваш Tutor):
# CSP_SCRIPT_SRC += ("https://chat.example.com",)
# CSP_FRAME_SRC += ("https://chat.example.com",)
# CSP_CONNECT_SRC += ("https://chat.example.com",)
