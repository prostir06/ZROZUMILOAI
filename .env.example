# Django
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
ALLOW_REGISTRATION=True

# Адміністратор (створюється автоматично при першому запуску)
DJANGO_ADMIN_USERNAME=admin
DJANGO_ADMIN_PASSWORD=change-me-admin-password
DJANGO_ADMIN_EMAIL=admin@localhost

# Database (Docker uses PostgreSQL, local dev can use SQLite)
# У Docker USE_SQLITE примусово False (див. docker-compose.yml)
POSTGRES_DB=zrozumiloai
POSTGRES_USER=zrozumiloai
POSTGRES_PASSWORD=zrozumiloai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
USE_SQLITE=True

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_QUEUE=512

# Gunicorn (Docker backend)
GUNICORN_WORKER_CLASS=gevent
GUNICORN_WORKERS=4
GUNICORN_WORKER_CONNECTIONS=1000
GUNICORN_TIMEOUT=300

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# Frontend
VITE_API_URL=/api

# Backup
BACKUP_DIR=./backup
FORCE_DB_RESTORE=0

# Auth rate limits (DRF throttle format, per client IP)
AUTH_LOGIN_RATE=10/minute
AUTH_REGISTER_RATE=5/minute
WIDGET_CHAT_RATE=60/minute

# RAG (документи workspace)
RAG_ENABLED=True
RAG_EMBED_MODEL=nomic-embed-text
RAG_EMBED_DIMENSIONS=768
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=4
RAG_MAX_FILE_SIZE=10485760
