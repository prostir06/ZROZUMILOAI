# Django
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_DEBUG=True
# Додайте IP/домен сервера для Docker/продакшену
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,192.168.31.233,zrozumiloai.freedynamicdns.net
ALLOW_REGISTRATION=True

# Адміністратор (створюється автоматично при першому запуску)
DJANGO_ADMIN_USERNAME=admin
DJANGO_ADMIN_PASSWORD=change-me-admin-password
DJANGO_ADMIN_EMAIL=admin@localhost

# Database (Docker uses PostgreSQL, local dev can use SQLite)
# У Docker USE_SQLITE примусово False (див. docker-compose.yml)
POSTGRES_DB=zrozumiloai
POSTGRES_USER=zrozumiloai
POSTGRES_PASSWORD=zrozumiloai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
USE_SQLITE=True

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_QUEUE=512

# Google Gemini (AI Studio API key)
# Отримайте ключ: https://aistudio.google.com/apikey
# Можна задати глобально тут або окремо для кожного workspace в адмін-панелі
GEMINI_API_KEY=
GEMINI_MODEL_NAMES=gemini-2.0-flash,gemini-2.5-flash-lite

# Опційний ключ Fernet для шифрування workspace API keys (інакше = DJANGO_SECRET_KEY)
FIELD_ENCRYPTION_KEY=

# Ліміти chat payload
CHAT_MAX_MESSAGES=100
CHAT_MAX_MESSAGE_CHARS=16000
CHAT_MAX_TOTAL_CHARS=120000

# Gunicorn (Docker backend)
GUNICORN_WORKER_CLASS=gevent
GUNICORN_WORKERS=4
GUNICORN_WORKER_CONNECTIONS=1000
GUNICORN_TIMEOUT=300

# CORS (додайте домени зовнішніх сайтів з віджетом, напр. Open edX)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost,http://localhost:80,http://127.0.0.1,http://192.168.31.233,https://zrozumiloai.freedynamicdns.net

# Frontend / Caddy
VITE_API_URL=/api
# Локально: :80. Продакшен з HTTPS: chat.example.com
CADDY_SITE_ADDRESS=:80

# Backup
BACKUP_DIR=./backup
FORCE_DB_RESTORE=0

# Auth rate limits (DRF throttle format, per client IP)
AUTH_LOGIN_RATE=10/minute
AUTH_REGISTER_RATE=5/minute
WIDGET_CHAT_RATE=60/minute

# Open edX Meilisearch (опційно, fallback для workspace)
# Локальний Tutor: http://meilisearch.local.openedx.io (без TLS)
MEILISEARCH_URL=
MEILISEARCH_API_KEY=
MEILISEARCH_INDEX_PREFIX=tutor_
MEILISEARCH_TIMEOUT_MS=5000
MEILISEARCH_MAX_CHUNK_CHARS=1200

# RAG (документи workspace)
RAG_ENABLED=True
RAG_EMBED_MODEL=nomic-embed-text
RAG_EMBED_DIMENSIONS=768
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=4
RAG_MAX_FILE_SIZE=10485760
