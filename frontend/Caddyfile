# Локально: :80 (HTTP). Продакшен: chat.example.com (авто HTTPS).
{$CADDY_SITE_ADDRESS::80} {
	encode gzip zstd

	root * /srv

	handle /api/* {
		reverse_proxy backend:8000 {
			flush_interval -1
			transport http {
				read_timeout 600s
				write_timeout 600s
			}
		}
	}

	handle /widget.js {
		header Cache-Control "public, max-age=3600"
		file_server
	}

	handle /embed.html {
		header Cache-Control "no-cache, no-store, must-revalidate"
		file_server
	}

	handle /demo-embed.html {
		file_server
	}

	handle /assets/* {
		header Access-Control-Allow-Origin "*"
		header Vary "Origin"
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle {
		try_files {path} {path}/ /index.html
		file_server
	}
}
